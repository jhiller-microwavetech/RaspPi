# PureThermal Mini Pro (GroupGets/FLIR) -- USB VID/PID 1e4e:0100.
# Verify with `lsusb` after plugging it in; edit idVendor/idProduct if
# your board reports differently.
SUBSYSTEM=="usb", ATTR{idVendor}=="1e4e", ATTR{idProduct}=="0100", MODE="0666", GROUP="video"
KERNEL=="video[0-9]*", SUBSYSTEM=="video4linux", ATTRS{idVendor}=="1e4e", ATTRS{idProduct}=="0100", MODE="0666", GROUP="video"
