[Unit]
Description=PureThermal Lepton 3.5 Viewer (kiosk)
After=graphical.target

[Service]
# Adjust User/Group and DISPLAY as appropriate for how your Pi boots
# (this assumes "Desktop Autologin" boot option and user "pi").
User=pi
Group=pi
Environment=DISPLAY=:0
Environment=XAUTHORITY=/home/pi/.Xauthority
WorkingDirectory=/home/pi/pt_thermal_viewer/src
ExecStart=/usr/bin/python3 /home/pi/pt_thermal_viewer/src/main.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical.target
